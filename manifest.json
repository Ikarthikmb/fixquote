{
  "manifest_version": 3,
  "name": "FixQuote",
  "version": "1.1.0",
  "description": "Build repair estimates in seconds. Add parts from Amazon, eBay, PhoneLCDParts or MobileSentrix — price captured automatically.",
  "permissions": [
    "storage",
    "contextMenus",
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs",
    "identity"
  ],
  "host_permissions": [
    "https://www.phonelcdparts.com/*",
    "https://phonelcdparts.com/*",
    "https://www.mobilesentrix.com/*",
    "https://mobilesentrix.com/*",
    "https://www.ebay.com/*",
    "https://ebay.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.phonelcdparts.com/*",
        "https://phonelcdparts.com/*",
        "https://www.mobilesentrix.com/*",
        "https://mobilesentrix.com/*",
        "https://www.ebay.com/*",
        "https://ebay.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "FixQuote",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
